# Template — copy this to a file named ".env" and paste your real key in.
#   cp .env.example .env
# The real .env is git-ignored; this .env.example is tracked so the repo
# documents what's needed (and so it travels to the Pi via git).
GEMINI_API_KEY=paste_your_key_here

# Optional: pin the exact model id (confirm the SKU name in aistudio.google.com).
# GEMINI_MODEL=gemini-3-flash
